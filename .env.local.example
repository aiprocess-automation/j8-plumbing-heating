# ─── Admin / visual editor (required) ────────────────────────────────────────
# 32+ random chars. Generate: openssl rand -hex 32
SESSION_SECRET=

# bcrypt hash of the initial admin password.
# Generate:
#   PW=$(openssl rand -base64 18); echo "Password: $PW"
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" "$PW"
ADMIN_PASSWORD_HASH=

# Vercel Blob store token. Auto-set in production when a Blob store is connected.
# Locally: create a Blob store in any Vercel project (Storage → Create → Blob),
# copy its read/write token, or run `vercel env pull .env.local` after linking.
BLOB_READ_WRITE_TOKEN=

# ─── Public site ─────────────────────────────────────────────────────────────
# Canonical URL — drives sitemap, robots, JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

